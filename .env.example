# CutPilot environment contract. Copy to `.env` on the Brev instance and fill in.
# All env reads in code go through `src/cutpilot/settings.py` (pydantic-settings).

# --- NVIDIA NIM (model serving) ------------------------------------------------
# Primary knob: which NIM endpoint the NAT workflow talks to.
# Self-hosted NIM on Brev (default):  http://localhost:8000/v1
# Hosted NIM (fallback):              https://integrate.api.nvidia.com/v1
NIM_BASE_URL=http://localhost:8000/v1

# API key for the hosted NIM fallback. Leave empty when using self-hosted NIM
# without auth; NAT's `_type: nim` provider accepts an empty api_key in that case.
NVIDIA_API_KEY=

# NGC credentials used to pull the NIM container on the Brev instance.
# Format: oauth token from ngc.nvidia.com.
NGC_API_KEY=

# --- Whisper (perception) ------------------------------------------------------
# Path to faster-whisper large-v3 weights on the Brev instance.
WHISPER_MODEL_PATH=./models/faster-whisper-large-v3
