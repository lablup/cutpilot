# CutPilot environment contract. Copy to `.env` on the Brev instance and fill in.
# All env reads in code go through `src/cutpilot/settings.py` (pydantic-settings).

# --- NVIDIA NIM: text reasoning model (Editor tool-calling) --------------------
# Nemotron-3 Nano 30B A3B served by NIM. OpenAI-compatible endpoint.
NIM_TEXT_BASE_URL=http://0.0.0.0:8000/v1
NIM_TEXT_MODEL=nvidia/nemotron-3-nano-30b-a3b

# --- NVIDIA NIM: vision-language model (Scout + any on-demand frame analysis) --
# Nemotron Nano 12B V2 VL served by NIM. Accepts image and video URLs.
NIM_VL_BASE_URL=http://0.0.0.0:9000/v1
NIM_VL_MODEL=nvidia/nemotron-nano-12b-v2-vl

# --- NVIDIA Riva: Whisper-Large ASR --------------------------------------------
# Riva gRPC endpoint (NOT OpenAI-compatible — uses the nvidia-riva-client SDK).
RIVA_SERVER=0.0.0.0:8100
# BCP-47 language code for transcription (e.g. en-US, ko-KR).
WHISPER_LANGUAGE=en-US

# --- Credentials ---------------------------------------------------------------
# For hosted-NIM fallback (integrate.api.nvidia.com). Leave empty on the Brev
# instance when talking to a self-hosted NIM without auth.
NVIDIA_API_KEY=
# For pulling NIM containers from nvcr.io on the Brev instance.
NGC_API_KEY=

# --- Output paths (resolved relative to repo root if not absolute) -------------
CUTPILOT_SOURCES_DIR=./sources
CUTPILOT_WORK_DIR=./work
CUTPILOT_OUTPUTS_DIR=./outputs
